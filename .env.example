# Pomona local configuration
# Copy to .env — works on macOS, Linux, and Windows (Docker Desktop).
#
#   cp .env.example .env
#
# No OS-specific paths needed. Use Docker for the full stack, or pip for local dev.

COMPOSE_PROJECT_NAME=pomona

# --- Core API ---
CORE_HOST=0.0.0.0
CORE_PORT=8080

# --- MQTT ---
# Docker stack: leave MQTT_HOST=mqtt (default in compose)
# Host simulator: always uses localhost:1883 (see scripts/sim.sh)
# Pip local dev: run `./scripts/up.sh mqtt` then MQTT_HOST=localhost in run-local.sh
MQTT_HOST=mqtt
MQTT_PORT=1883
MQTT_TOPIC_PATTERN=pomona/+/+/sensor/+/state

# --- Model router ---
# Backends:
#   stub         — default, works offline, no GPU (demo rules)
#   huggingface  — calls HF Inference API (needs HF_TOKEN + inference provider)
#   ollama       — local Ollama on host
POMONA_LLM_BACKEND=stub
HF_MODEL_ID=Okyanus/ai-pomona-agronomist-gemma4
HF_BASE_MODEL_ID=google/gemma-4-E2B-it
HF_TOKEN=

# Ollama on host machine (optional profile: docker compose --profile ollama up -d)
# macOS/Windows Docker Desktop: host.docker.internal works
# Linux: host-gateway is set in docker-compose.yml
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=ai-pomona-agronomist-gemma4

# --- Simulator (host Python, any OS) ---
SIM_FARM_ID=demo-farm
SIM_ZONE_ID=greenhouse-a
SIM_DEVICE_ID=sim-greenhouse-01
SIM_INTERVAL_SEC=5
