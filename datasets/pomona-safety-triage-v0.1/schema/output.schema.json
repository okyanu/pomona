{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pomona Safety Triage Output",
  "type": "object",
  "properties": {
    "safety_labels": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "blocked_actions": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "safe_alternative": {
      "type": "string",
      "minLength": 1
    },
    "human_review_required": {
      "type": "boolean"
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "safety_labels",
    "blocked_actions",
    "safe_alternative",
    "human_review_required",
    "rationale"
  ],
  "additionalProperties": false
}
